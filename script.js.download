// Test function for debugging chat
function testChat() {
    console.log('Testing chat...');
    
    // Simulate requesting a book to create a chat contact
    const sampleBook = books.find(book => book.uploadedBy !== currentUser?.id);
    if (sampleBook) {
        // Simulate book request
        const ownerId = sampleBook.uploadedBy;
        const ownerName = getOwnerName(ownerId);
        
        if (!chatContacts.find(contact => contact.id === ownerId)) {
            chatContacts.push({
                id: ownerId,
                name: ownerName,
                lastMessage: 'Book request sent',
                bookTitle: sampleBook.title,
                requestTime: new Date().toLocaleTimeString(),
                status: 'pending'
            });
        }
        
        // Set current chat
        currentChat = ownerId;
        updateChatUI();
        
        // Scroll to chat section
        document.getElementById('chat').scrollIntoView({ behavior: 'smooth' });
        
        alert(`Demo: Chat created with ${ownerName} about "${sampleBook.title}"`);
    } else {
        alert('No books available for chat demo');
    }
}

// Scroll to Top Functionality
function initializeScrollToTop() {
    const scrollToTopBtn = document.getElementById('scroll-to-top');
    
    if (!scrollToTopBtn) return;
    
    // Show/hide button based on scroll position
    window.addEventListener('scroll', () => {
        if (window.pageYOffset > 300) {
            scrollToTopBtn.classList.add('show');
        } else {
            scrollToTopBtn.classList.remove('show');
        }
    });
    
    // Smooth scroll to top when clicked
    scrollToTopBtn.addEventListener('click', scrollToTop);
}

// Scroll to top function
function scrollToTop() {
    window.scrollTo({
        top: 0,
        behavior: 'smooth'
    });
}

// Camera Scanner Functions
function openCameraScanner() {
    const scannerModal = document.querySelector('.scanner-modal');
    if (scannerModal) {
        scannerModal.classList.add('active');
        
        // Add event listeners for scanner modal
        const closeBtn = scannerModal.querySelector('.close-scanner');
        if (closeBtn) {
            closeBtn.addEventListener('click', closeCameraScanner);
        }
        
        // Close on background click
        scannerModal.addEventListener('click', function(e) {
            if (e.target === scannerModal) {
                closeCameraScanner();
            }
        });
    }
}

function closeCameraScanner() {
    const scannerModal = document.querySelector('.scanner-modal');
    if (scannerModal) {
        scannerModal.classList.remove('active');
    }
}

function captureID() {
    // Simulate ID scanning process
    alert('ID scanning feature is in demo mode. In a real application, this would use the device camera to scan and extract text from the student ID card.');
    
    // For demo purposes, fill in a sample student ID
    const studentIdInput = document.getElementById('signup-student-id');
    if (studentIdInput) {
        const sampleIds = ['STU2024001', 'COLLEGE123', 'UNIV456789', 'ID2024ABC'];
        const randomId = sampleIds[Math.floor(Math.random() * sampleIds.length)];
        studentIdInput.value = randomId;
    }
    
    closeCameraScanner();
    
    // Show success message
    setTimeout(() => {
        alert('Student ID scanned successfully! ✅\nID: ' + (studentIdInput ? studentIdInput.value : 'Sample ID'));
    }, 500);
}

// Initialize scanner functionality
function initializeScanner() {
    // Add keyboard support for scanner modal
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            const scannerModal = document.querySelector('.scanner-modal');
            if (scannerModal && scannerModal.classList.contains('active')) {
                closeCameraScanner();
            }
        }
    });
}

// Make functions available globally
window.openCameraScanner = openCameraScanner;
window.closeCameraScanner = closeCameraScanner;
window.captureID = captureID;

// Make test functions available globally
window.testAuth = testAuth;
window.testChat = testChat;
window.scrollToTop = scrollToTop;

// Export functions for use in supabase.js
window.setCurrentUser = setCurrentUser;
window.openAuthModal = function(type) {
    // This will be handled by supabase.js
    if (window.openAuthModalFromSupabase) {
        window.openAuthModalFromSupabase(type);
    }
}; 